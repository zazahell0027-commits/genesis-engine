 function isTextInputElement(target: EventTarget | null): boolean {
   if (!(target instanceof HTMLElement)) return false;
   const tag = target.tagName;
   return tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || target.isContentEditable;
 }
+
+function getCountryStrategicTone(country: GameState["countries"][number], playerCountryId: string): {
+  title: string;
+  detail: string;
+} {
+  if (country.id === playerCountryId) {
+    if (country.unrest >= 55 || country.stability <= 45) {
+      return {
+        title: "Front interieur fragile",
+        detail: "Priorite a la stabilisation, a l'ordre public et a la reprise economique avant une escalade externe."
+      };
+    }
+
+    return {
+      title: "Pilotage national",
+      detail: "Utilisez surtout les actions internes pour renforcer l'economie, la cohesion et la capacite militaire avant le prochain round."
+    };
+  }
+
+  if (country.army >= 70 || country.tension >= 65) {
+    return {
+      title: "Risque de theatre exterieur",
+      detail: "Cette puissance peut repondre rapidement. Toute action offensive ou demonstrative doit etre accompagnee d'un contexte diplomatique clair."
+    };
+  }
+
+  return {
+    title: "Fenetre diplomatique ou coercitive",
+    detail: "Le pays selectionne peut etre influence par pression, defense regionale ou opportunite de negociation."
+  };
+}
