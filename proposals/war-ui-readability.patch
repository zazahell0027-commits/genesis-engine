@@
 .quick-action-card {
   flex-direction: column;
   cursor: pointer;
 }
+
+.selected-country-context {
+  margin-top: 0.8rem;
+  display: grid;
+  gap: 0.8rem;
+}
+
+.selected-country-context-copy strong,
+.country-context-card strong,
+.country-context-card span,
+.action-section-header strong,
+.action-section-header span {
+  display: block;
+}
+
+.selected-country-context-copy p {
+  margin: 0.3rem 0 0;
+  color: var(--muted);
+  line-height: 1.5;
+}
+
+.country-context-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 0.65rem;
+}
+
+.country-context-card {
+  padding: 0.8rem 0.9rem;
+  border-radius: 1rem;
+  border: 1px solid var(--line);
+  background: rgba(255, 255, 255, 0.78);
+}
+
+.country-context-card span {
+  color: var(--muted);
+  font-size: 0.76rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+}
+
+.country-context-card strong {
+  margin-top: 0.35rem;
+  font-size: 1.25rem;
+}
+
+.country-context-card.tone-tension {
+  border-color: rgba(239, 63, 113, 0.2);
+}
+
+.country-context-card.tone-stability {
+  border-color: rgba(79, 168, 114, 0.18);
+}
+
+.country-context-card.tone-army {
+  border-color: rgba(127, 78, 246, 0.18);
+}
+
+.action-section {
+  margin-top: 1rem;
+  display: grid;
+  gap: 0.8rem;
+}
+
+.action-section.secondary-actions {
+  margin-top: 0.9rem;
+}
+
+.action-section-header {
+  display: grid;
+  gap: 0.2rem;
+}
+
+.action-section-header span {
+  color: var(--muted);
+  line-height: 1.45;
+}
+
+.quick-action-row-emphasis .quick-action-card {
+  box-shadow: 0 12px 26px rgba(20, 25, 38, 0.08);
+}
+
+.quick-action-row-secondary .quick-action-card {
+  background: rgba(255, 255, 255, 0.66);
+}
+
+.quick-action-card.kind-attack {
+  border-color: rgba(239, 63, 113, 0.24);
+  background: linear-gradient(180deg, rgba(255, 110, 127, 0.12), rgba(255, 255, 255, 0.9));
+}
+
+.quick-action-card.kind-defend {
+  border-color: rgba(111, 57, 243, 0.22);
+  background: linear-gradient(180deg, rgba(141, 99, 255, 0.12), rgba(255, 255, 255, 0.9));
+}
+
+.quick-action-card.kind-invest {
+  border-color: rgba(209, 136, 34, 0.24);
+  background: linear-gradient(180deg, rgba(240, 180, 90, 0.12), rgba(255, 255, 255, 0.9));
+}
